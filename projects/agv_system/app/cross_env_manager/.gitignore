# 配置文件（含敏感信息）
config/*.toml
config/old/*
config/env.toml

# 测试文件（压力测试脚本除外）
test/*
!test/调车模块压力测试/
test_*

# SQL 文件
*.sql

# 配置管理相关文件
static/js/config.js
static/js/backups/*

# 开发环境文件
.env
.env.local
*.log

# 调车模块数据文件
data/

# Python 虚拟环境
venv/

# 备份文件
backup/

# 开发调试文件
dev/

# Python 缓存
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# IDE
.vscode/
.idea/
plans/*

# supervisor日志目录（保留目录结构，忽略日志文件）
logs/*
!logs/.gitkeep
